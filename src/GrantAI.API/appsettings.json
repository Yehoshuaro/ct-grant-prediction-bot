{
  "Mongo": {
    "ConnectionString": "mongodb://localhost:27017",
    "Database": "grantai"
  },
  "Redis": {
    "ConnectionString": "localhost:6379,abortConnect=false"
  },
  "Cache": {
    "HistoryMinutes": 60,
    "ForecastMinutes": 120,
    "ChanceMinutes": 30,
    "SpecialtiesMinutes": 60,
    "StatisticsMinutes": 30
  },
  "RateLimit": {
    "Global": { "PermitLimit": 120, "WindowSeconds": 60, "QueueLimit": 0 },
    "Strict": { "PermitLimit": 10, "WindowSeconds": 60, "QueueLimit": 0 }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  },
  "AllowedHosts": "*"
}
