# Copy this file to ".env" and fill in the values before running docker compose.

# Telegram bot token issued by @BotFather (required for the bot to start).
TELEGRAM_BOT_TOKEN=000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Mongo root credentials used by the mongo container and the connection strings.
MONGO_INITDB_ROOT_USERNAME=grantai
MONGO_INITDB_ROOT_PASSWORD=grantai_password
